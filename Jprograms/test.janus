procedure add(int x, int n)
    show(x)
    show(n)
    if n = 0 then   
        //skip
    else
        n-=1
        x+=1
        call add(x, n)
    fi n = 0
    show(x)
    show(n)

procedure main()
    local stack s = nil
    local int n = 1
    int x
    call add(x, n)
    show(s)
    uncall add(x, n)
    delocal int n = 1
    delocal stack s = nil