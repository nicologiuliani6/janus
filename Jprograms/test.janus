procedure main()
    stack s
    int n_orig

    n_orig += 10

    from n_orig = n_orig loop
        local int n = n_orig
        push(n, s)
        delocal int n = 0
        n_orig -= 1
    until n_orig = 0

    show(s)

    from n_orig = 0 loop
        n_orig += 1
        local int n = 0
        pop(n, s)
        delocal int n = n_orig
    until n_orig = 10
    show(s)