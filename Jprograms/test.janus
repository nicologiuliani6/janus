procedure check_boolean(int flag)
    flag-=flag
    flag+=1
    if flag = 1 then
        //do something
        show(flag)
    else
        //do something
        local int x = 5
        show(x)
        delocal int x = 5
    fi flag = 1

procedure main()
    local int flag = 0
    call check_boolean(flag)
    uncall check_boolean(flag)
    delocal int flag = 0
    