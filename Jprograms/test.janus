procedure encrypt(int x, int key)
    int k 
    k+=key
    if key = 0 then
        //skip
    else 
        x += k
        k -= 1
        call encrypt(x, k)
    fi key = 0
    


procedure main()
    local int key = 10
    local int msg = 0
    show(msg)
    show(key)
    call encrypt(msg, key)
    show(msg)
    show(key)
    uncall encrypt(msg, key)
    show(msg) //deve tornare a 0
    show(key)
    delocal int msg = 0
    delocal int key = 10
